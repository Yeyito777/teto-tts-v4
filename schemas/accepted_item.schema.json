{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Yeyito777/teto-tts-v4/schemas/accepted_item.schema.json",
  "title": "Teto v4 accepted dataset item",
  "type": "object",
  "required": ["schema_version", "id", "audio_path", "text", "prompt_text", "duration_sec", "split", "style", "qc"],
  "properties": {
    "schema_version": { "const": "teto.accepted.v1" },
    "id": { "type": "string", "pattern": "^teto_v4_[0-9]{8,}$" },
    "audio_path": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "prompt_text": { "type": "string", "minLength": 1 },
    "duration_sec": { "type": "number", "exclusiveMinimum": 0 },
    "split": { "enum": ["train", "val", "test"] },
    "style": {
      "type": "object",
      "required": ["emphasis", "emotion", "intensity"],
      "properties": {
        "emphasis": { "type": "boolean" },
        "emotion": { "type": "string", "minLength": 1 },
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "qc": {
      "type": "object",
      "required": ["accepted", "asr_text", "wer", "final_words_present", "duration_ok", "not_clipped", "not_silent", "loudness_ok", "manual_review"],
      "properties": {
        "accepted": { "const": true },
        "asr_text": { "type": "string" },
        "wer": { "type": ["number", "null"], "minimum": 0 },
        "final_words_present": { "type": "boolean" },
        "duration_ok": { "type": "boolean" },
        "not_clipped": { "type": "boolean" },
        "not_silent": { "type": "boolean" },
        "loudness_ok": { "type": "boolean" },
        "manual_review": { "enum": ["not_required", "passed", "failed"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
